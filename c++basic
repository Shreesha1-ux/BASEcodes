// swapping

#include<bits/stdc++.h>
using namespace std;
int main(){
    int a ,b,temp;
    cout<<"enter the values for a and b";
    cin>>a>>b;
    cout<<"before swapping a="<<a<<"b="<<b;
    temp=a;
    a=b;
    b=temp;
    cout<<"after swapping a="<<a<<"b="<<b;
    return 0;
    
}

